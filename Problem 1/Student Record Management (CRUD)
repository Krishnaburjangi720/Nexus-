students = []

def add_student():
    # read and validate inputs
    sid = input("Enter Student ID: ").strip()
    if any(s["id"] == sid for s in students):
        print("A student with that ID already exists.")
        return

    name = input("Enter Name: ").strip()
    if not name:
        print("Name cannot be empty")
        return

    age_str = input("Enter Age: ").strip()
    try:
        age = int(age_str)
    except ValueError:
        print("Age must be an integer")
        return

    students.append({
        "id": sid,
        "name": name,
        "age": age
    })
    print("Student added successfully")

def view_students():
    if not students:
        print("No student records found")
        return
    for s in students:
        print(f"ID: {s['id']}, Name: {s['name']}, Age: {s['age']}")

def update_student():
    sid = input("Enter Student ID to update: ").strip()
    for s in students:
        if s["id"] == sid:
            new_name = input("Enter new name: ").strip()
            if new_name:
                s["name"] = new_name
            age_str = input("Enter new age: ").strip()
            if age_str:
                try:
                    s["age"] = int(age_str)
                except ValueError:
                    print("Invalid age, skipping update of age")
            print("Student updated")
            return
    print("Student not found")

def delete_student():
    sid = input("Enter Student ID to delete: ")
    for s in students:
        if s["id"] == sid:
            students.remove(s)
            print("Student deleted")
            return
    print("Student not found")

def menu():
    while True:
        print("\n1.Add  2.View  3.Update  4.Delete  5.Exit")
        choice = input("Enter choice: ")

        if choice == "1":
            add_student()
        elif choice == "2":
            view_students()
        elif choice == "3":
            update_student()
        elif choice == "4":
            delete_student()
        elif choice == "5":
            break
        else:
            print("Invalid choice")

menu()
